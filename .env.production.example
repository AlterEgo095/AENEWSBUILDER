# ============================================
# AENEWS BUILDER - Production Environment (VPS)
# ============================================
# ⚠️  SECURITY WARNING: Never commit this file to Git!
# Copy this file to .env on your VPS:
#   cp .env.production.example .env
#   nano .env  # Then fill in ALL values
# ============================================

# ============================================
# 🔐 REQUIRED: AI API Keys
# ============================================

# OpenAI (GPT-4o, GPT-4o-mini for AI Failover Cascade)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Anthropic (Claude 3 Haiku, Sonnet, Opus for AI Failover Cascade)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ============================================
# 🔐 REQUIRED: Database
# ============================================

# PostgreSQL — MUST match docker-compose POSTGRES_DB
DATABASE_URL=postgresql://aenews:YOUR_SECURE_POSTGRES_PASSWORD@postgres:5432/aenews_builder?schema=public

# Redis — for BullMQ queues, cache, pub/sub, SSE
REDIS_URL=redis://:YOUR_SECURE_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# Docker compose also reads these for container setup:
POSTGRES_PASSWORD=YOUR_SECURE_POSTGRES_PASSWORD

# ============================================
# 🔐 REQUIRED: Authentication (JWT RS256)
# ============================================

# HMAC fallback secret (RS256 keys are primary)
JWT_SECRET=your-hmac-secret-fallback-min-32-chars-long-recommended-64

# JWT expiry
JWT_EXPIRES_IN=7d

# JWT RSA key paths (generated by deploy.sh in secrets/)
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# ============================================
# 🌐 REQUIRED: Server Configuration
# ============================================

NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

# ⚠️ REPLACE with your actual domain or VPS IP
FRONTEND_URL=https://yourdomain.com

# CORS Origins (comma-separated, match your domain)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# 🛡️  Security (Production Hardening)
# ============================================

# Helmet + HSTS + CSP
HELMET_ENABLED=true
CSP_ENABLED=true

# Rate Limiting (production-tuned)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# ⚡ Performance & Caching (Production)
# ============================================

CACHE_TTL_CLASSIFICATION=86400
CACHE_TTL_PLAN=3600
CACHE_TTL_GENERATION=1800

# ============================================
# 🧠 AI Engine Configuration
# ============================================

MAX_TOKENS_PER_REQUEST=8000
MAX_TOKENS_PER_FILE=4000

# Cost Management
COST_ALERT_THRESHOLD_DAILY=10.00
COST_ALERT_THRESHOLD_MONTHLY=100.00

# ============================================
# ⚙️ Worker & Queue Configuration
# ============================================

BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3
AUTO_HEALING_MAX_RETRIES=3
AUTO_HEALING_ESCALATE_MODEL=claude-3-opus

# ============================================
# 🐳 Sandbox Configuration
# ============================================

SANDBOX_NETWORK=none
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT=30000
SANDBOX_POOL_SIZE=3
SANDBOX_POOL_STACKS=react,next,express

# ============================================
# 🔌 MCP Tool API Keys (Optional)
# ============================================
# Uncomment and fill in only the ones you need:

# Figma
# FIGMA_ACCESS_TOKEN=figd_YOUR_KEY

# Notion
# NOTION_API_KEY=secret_YOUR_KEY

# Cloudflare
# CLOUDFLARE_API_TOKEN=YOUR_TOKEN
# CLOUDFLARE_ZONE_ID=YOUR_ZONE_ID

# Vercel
# VERCEL_TOKEN=YOUR_TOKEN

# Replicate (Media Generation)
# REPLICATE_API_TOKEN=r8_YOUR_TOKEN

# Slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# 📊 Monitoring (Optional)
# ============================================

# Sentry Error Tracking
# SENTRY_DSN=https://YOUR_KEY@sentry.io/PROJECT_ID
# SENTRY_ENVIRONMENT=production

# Grafana (REQUIRED — set a strong password)
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# ============================================
# 📧 Notifications (Optional)
# ============================================

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
