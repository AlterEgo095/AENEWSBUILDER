# ========================================
# AENEWSBUILDER - Environment Template
# Copy to .env and fill in your values
# ========================================

# Application
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

# PostgreSQL
POSTGRES_PASSWORD=your_secure_postgres_password
DATABASE_URL=postgresql://aenews:your_secure_postgres_password@localhost:5432/aenews_builder?schema=public
DATABASE_READ_URL=postgresql://aenews:your_secure_postgres_password@localhost:5434/aenews_builder?schema=public

# Redis
REDIS_PASSWORD=your_secure_redis_password
REDIS_URL=redis://:your_secure_redis_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis Sentinel (optional)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_HOST_1=redis-sentinel-1
REDIS_SENTINEL_HOST_2=redis-sentinel-2
REDIS_SENTINEL_HOST_3=redis-sentinel-3

# JWT Authentication
JWT_SECRET=your_128_char_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# Frontend
FRONTEND_URL=https://studio.aenews.net
CORS_ORIGINS=https://studio.aenews.net,https://aenews.net

# Security
HELMET_ENABLED=true
CSP_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ENABLED=true

# Token Limits
MAX_TOKENS_PER_REQUEST=32768
COST_ALERT_THRESHOLD_DAILY=10
COST_ALERT_THRESHOLD_MONTHLY=200

# Worker Configuration
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3
AUTO_HEALING_MAX_RETRIES=3
AUTO_HEALING_ESCALATE_MODEL=qwen-max

# Sandbox
SANDBOX_NETWORK=aenews-sandbox
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT=30000
SANDBOX_POOL_SIZE=3
SANDBOX_POOL_STACKS=

# Caching TTL (seconds)
CACHE_TTL_CLASSIFICATION=86400
CACHE_TTL_PLAN=3600
CACHE_TTL_GENERATION=1800

# Monitoring
GRAFANA_ADMIN_PASSWORD=your_grafana_password
PROMETHEUS_URL=http://localhost:9090

# Admin Seed
ADMIN_EMAIL=admin@aenews.net
ADMIN_PASSWORD=your_secure_admin_password

# Registration
REGISTRATION_ENABLED=true

# MCP Tools (optional)
MCP_REGISTRY_SECRET=
FIGMA_ACCESS_TOKEN=
NOTION_API_KEY=
PLAYWRIGHT_BASE_URL=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
SUPABASE_ACCESS_TOKEN=
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SERPAPI_KEY=

# Worker Mode
WORKER_MODE=false

# VPS DevOps Agent (optional)
VPS_DEVOPS_PORT=4010

