# ============================================
# AENEWS BUILDER - Environment Configuration
# ============================================
# ⚠️  SECURITY WARNING: Never commit this file to Git!
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# 🔐 API KEYS
# ============================================

# OpenAI (GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude Sonnet, Opus)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Alibaba Cloud DashScope (Qwen models, 100+ models, OpenAI-compatible)
# Get your key: https://modelstudio.console.alibabacloud.com
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ENABLED=true

# Replicate (Media Generation)
REPLICATE_API_TOKEN=your-replicate-token-here

# ============================================
# 🗄️  DATABASE
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://aenews:aenews_secure_password@localhost:5432/aenews_builder?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=aenews_redis_secure_password

# ============================================
# 🔑 AUTHENTICATION
# ============================================

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars-recommended-64
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=RS256

# JWT RSA Keys (generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# Admin User (first user created)
ADMIN_EMAIL=admin@aenews.ai
ADMIN_PASSWORD=change-this-secure-password

# ============================================
# 🌐 SERVER CONFIGURATION
# ============================================

# API Gateway
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ============================================
# 🐳 DOCKER CONFIGURATION
# ============================================

# Sandbox
SANDBOX_NETWORK=none
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT=30000

# Warm Pool Configuration
SANDBOX_POOL_SIZE=3
SANDBOX_POOL_STACKS=react,next,express

# ============================================
# 🔌 MCP TOOLS
# ============================================

# Figma
FIGMA_ACCESS_TOKEN=your-figma-token-here

# Notion
NOTION_API_KEY=secret_your-notion-key-here

# Cloudflare (Deploy + WAF)
CLOUDFLARE_API_TOKEN=your-cloudflare-token-here
CLOUDFLARE_ZONE_ID=your-zone-id-here

# Vercel (Alternative Deploy)
VERCEL_TOKEN=your-vercel-token-here

# ============================================
# 📊 MONITORING
# ============================================

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin-secure-password

# ============================================
# ⚡ PERFORMANCE & CACHING
# ============================================

# Cache TTL (seconds)
CACHE_TTL_CLASSIFICATION=86400
CACHE_TTL_PLAN=3600
CACHE_TTL_GENERATION=1800

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 🛡️  SECURITY
# ============================================

# Helmet Configuration
HELMET_ENABLED=true

# Content Security Policy
CSP_ENABLED=true

# IP Whitelist (optional, comma-separated)
IP_WHITELIST=

# ============================================
# 💰 COST MANAGEMENT
# ============================================

# Token Limits
MAX_TOKENS_PER_REQUEST=8000
MAX_TOKENS_PER_FILE=4000

# Cost Alerts (USD)
COST_ALERT_THRESHOLD_DAILY=10.00
COST_ALERT_THRESHOLD_MONTHLY=100.00

# ============================================
# 🔧 WORKER CONFIGURATION
# ============================================

# BullMQ
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3

# Auto-Healing
AUTO_HEALING_MAX_RETRIES=3
AUTO_HEALING_ESCALATE_MODEL=claude-3-opus

# State Machine
STATE_MACHINE_TIMEOUT=300000

# ============================================
# 📧 NOTIFICATIONS (Optional)
# ============================================

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Slack (Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# 🚀 DEPLOYMENT (VPS)
# ============================================

# VPS Configuration
VPS_HOST=your-vps-ip-or-domain
VPS_USER=aenews
VPS_SSH_KEY_PATH=~/.ssh/id_rsa
VPS_DEPLOY_PATH=/opt/aenews-builder

# Domain
DOMAIN=aenews.ai
SSL_ENABLED=true

# ============================================
# 🧪 TESTING
# ============================================

# Test Database
TEST_DATABASE_URL=postgresql://test:test@localhost:5433/aenews_test

# Test Mode
TEST_MODE=false
MOCK_AI_RESPONSES=false
